# 扫描 opencode.json, 输出 TSV (一组 + 诊断)
#   A|<name>|<runner>|<pkg>   MCP local command (runner 必须是 bunx/npx)
#   B|<name>                  plugin 数组条目 (去重)
#   C|<name>                  provider.*.npm 字段值 (内置包, 调用方需跳过)
#   W|<msg>                   warn: 配置异常 (如 command 形如不匹配)
#   I|<msg>                   info: 跳过 (如 runner 非 bunx/npx)
# 失败: opencode.json 缺失/解析失败 → 返回非 0 + stderr 错误
_scan_opencode_packages() {
    local cfg="$OC_CONFIG_FILE"
    if [ ! -f "$cfg" ]; then
        echo "[err] opencode.json 不存在: $cfg" >&2
        return 1
    fi
    python3 - "$cfg" <<'PYEOF'
import json, sys
try:
    with open(sys.argv[1], encoding="utf-8") as f:
        cfg = json.load(f)
except json.JSONDecodeError as e:
    print(f"[err] opencode.json 解析失败: {e}", file=sys.stderr)
    sys.exit(1)

# Group A: MCP local command (runner 必须是 bunx/npx)
for name, mcp in cfg.get("mcp", {}).items():
    if mcp.get("type") != "local":
        continue
    cmd = mcp.get("command", []) or []
    if len(cmd) < 2:
        print(f"W|mcp.{name}.command 形如 [runner, pkg], 实际 {cmd}")
        continue
    runner, pkg = cmd[0], cmd[1]
    if runner not in ("bunx", "npx"):
        print(f"I|mcp.{name} runner={runner} 非 bunx/npx, 跳过")
        continue
    print(f"A|{name}|{runner}|{pkg}")

# Group B: plugin 列表 (去重)
seen = set()
for pkg in cfg.get("plugin", []):
    if pkg in seen:
        continue
    seen.add(pkg)
    print(f"B|{pkg}")

# Group C: provider.*.npm (内置包, 仅列出)
for _pname, prov in cfg.get("provider", {}).items():
    npm = prov.get("npm", "")
    if npm:
        print(f"C|{npm}")
PYEOF
}

# 刷新一个 bunx/npx 包 (MCP local)
# 参数: name (MCP 条目名), runner (bunx|npx), pkg_spec (形如 name@latest 或 name)
# DRY_RUN=1 时跳过真实 bun pm cache rm / bunx, 仅打印
_refresh_bunx_package() {
    local name="$1" runner="$2" pkg_spec="$3"
    if [ -z "$pkg_spec" ]; then
        warn "$name: 缺少包名, 跳过"
        return 0
    fi
    case "$pkg_spec" in
        *@*) ;;
        *)   pkg_spec="${pkg_spec}@latest" ;;
    esac

    if [ "$runner" = "npx" ] || ! command -v bun >/dev/null 2>&1; then
        warn "$name: 需 bun (当前 runner=$runner); 请在 TUI「插件管理」菜单选择「切换 think MCP 到 bunx」后再刷"
        return 0
    fi

    if [ "${DRY_RUN:-0}" = "1" ]; then
        info "[DRY_RUN] $name: 跳过 bun pm cache rm + bunx $pkg_spec"
        ok "$name: $pkg_spec (dry-run)"
        return 0
    fi

    info "清除 $name bun 缓存..."
    bun pm cache rm 2>/dev/null || true

    info "重新拉取 $name 最新版..."
    _run_with_timeout 15 bunx "$pkg_spec" --version 2>/dev/null &
    wait $! 2>/dev/null || true

    local bare_name="${pkg_spec%@*}"
    local cached
    cached=$(_find_bun_cache_package "$bare_name" || true)
    if [ -n "$cached" ]; then
        ok "$name: $(basename "$cached")"
    else
        warn "$name: 未找到缓存, 首次启动时会自动拉取"
    fi
}

# 刷新一个 npm plugin 包
# 参数: name (plugin 条目名)
# DRY_RUN=1 时跳过真实 npm update, 仅打印
_refresh_npm_package() {
    local name="$1"
    local oc_dir
    oc_dir=$(dirname "$OC_CONFIG_FILE")

    if [ ! -f "${oc_dir}/package.json" ]; then
        warn "$name: opencode 目录无 package.json, 首次启动时会自动拉取"
        return 0
    fi
    if ! command -v npm >/dev/null 2>&1; then
        warn "$name: npm 未安装, 跳过"
        return 0
    fi

    if [ "${DRY_RUN:-0}" = "1" ]; then
        info "[DRY_RUN] $name: 跳过 npm update $name"
        ok "$name: v? (dry-run)"
        return 0
    fi

    info "更新 $name (npm update)..."
    if (cd "$oc_dir" && npm update "$name" 2>/dev/null); then
        local ver
        ver=$(cd "$oc_dir" && node -e "try{console.log(require('${name}/package.json').version)}catch(e){console.log('?')}" 2>/dev/null || echo "?")
        ok "$name: v${ver}"
    else
        warn "$name: npm update 失败, opencode 启动时会自动拉取"
    fi
}

_refresh_global_npm_package() {
    local name="$1"
    local npm_runner=""
    if command -v bun >/dev/null 2>&1; then
        npm_runner="bun"
    elif command -v npm >/dev/null 2>&1; then
        npm_runner="npm"
    else
        warn "$name: bun/npm 均未安装, 跳过"
        return 0
    fi

    if [ "${DRY_RUN:-0}" = "1" ]; then
        info "[DRY_RUN] $name: 跳过 $npm_runner install -g $name@latest"
        ok "$name: v? (dry-run)"
        return 0
    fi

    info "更新全局工具 $name..."
    if $npm_runner install -g "$name"@latest 2>&1; then
        local ver
        ver=$($name --version 2>/dev/null || echo "?")
        ok "$name: v${ver}"
    else
        warn "$name: 全局更新失败"
    fi
}

# 刷新所有插件缓存 (从 opencode.json 全量扫描)
# 环境变量: DRY_RUN=1 跳过真实网络/磁盘 (用于测试/预览)
plugins_refresh_cache() {
    echo
    echo "${C_BOLD}刷新 NPM 工具${C_RESET}"
    echo

    if [ ! -f "$OC_CONFIG_FILE" ]; then
        warn "opencode 配置文件不存在: $OC_CONFIG_FILE"
        return 1
    fi
    if ! command -v python3 &>/dev/null; then
        warn "python3 未安装 (JSON 操作需要)"
        return 1
    fi

    local scan_output
    if ! scan_output=$(_scan_opencode_packages); then
        warn "扫描 opencode.json 失败 (见上方错误)"
        return 1
    fi

    # 分组
    local -a builtin_names=()
    local mcp_n=0 plugin_n=0 builtin_n=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        case "$line" in
            A\|*)
                mcp_n=$((mcp_n+1))
                local name runner pkg
                name=$(echo "$line" | cut -d'|' -f2)
                runner=$(echo "$line" | cut -d'|' -f3)
                pkg=$(echo "$line" | cut -d'|' -f4)
                _refresh_bunx_package "$name" "$runner" "$pkg" || true
                ;;
            B\|*)
                plugin_n=$((plugin_n+1))
                local name
                name=$(echo "$line" | cut -d'|' -f2)
                _refresh_npm_package "$name" || true
                ;;
            C\|*)
                builtin_n=$((builtin_n+1))
                builtin_names+=("$(echo "$line" | cut -d'|' -f2)")
                ;;
            W\|*)
                warn "$(echo "$line" | cut -d'|' -f2-)"
                ;;
            I\|*)
                info "$(echo "$line" | cut -d'|' -f2-)"
                ;;
        esac
    done <<< "$scan_output"

    if [ "${#builtin_names[@]}" -gt 0 ]; then
        info "跳过 ${#builtin_names[@]} 个内置包: $(IFS=,; echo "${builtin_names[*]}")"
    fi
    _refresh_global_npm_package "codegraph" || true
    info "扫描结果: $mcp_n 个 MCP 包, $plugin_n 个 plugin 包, $builtin_n 个内置 ai-sdk 包"
}

