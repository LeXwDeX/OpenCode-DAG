# env_check_and_inject — 检查所需环境变量，缺失则注入 RC 文件
env_check_and_inject() {
    local rc_file=""
    if [ -n "${ZSH_VERSION:-}" ] || [ "$SHELL" = "/usr/bin/zsh" ] || [ "$SHELL" = "/bin/zsh" ]; then
        rc_file="${HOME}/.zshrc"
    elif [ -n "${BASH_VERSION:-}" ] || [ "$SHELL" = "/bin/bash" ] || [ "$SHELL" = "/usr/bin/bash" ]; then
        rc_file="${HOME}/.bashrc"
    fi

    if [ -z "$rc_file" ]; then
        warn "无法检测 shell 类型，请手动添加环境变量"
        for var_line in "${OC_ENV_VARS[@]}"; do
            echo "  export $var_line"
        done
        return 1
    fi

    [ -f "$rc_file" ] || touch "$rc_file"
    info "目标 RC 文件: $rc_file"

    local injected=0 skipped=0
    for var_line in "${OC_ENV_VARS[@]}"; do
        local var_name="${var_line%%=*}"
        if grep -qE "^[[:space:]]*export[[:space:]]+${var_name}=" "$rc_file" 2>/dev/null; then
            info "已存在: export $var_line"
            skipped=$((skipped + 1))
        else
            echo "export $var_line" >> "$rc_file"
            ok "已添加: export $var_line"
            injected=$((injected + 1))
        fi
    done

    echo
    if [ "$injected" -gt 0 ]; then
        ok "共注入 $injected 个变量到 $rc_file"
        info "已跳过 $skipped 个已存在的变量"
        warn "请执行 \`source $rc_file\` 或重新打开终端使其生效"
    else
        ok "所有环境变量已存在，无需注入"
    fi
}

