# 扫描 opencode.json, 输出 TSV (一组 + 诊断)
#   A|<name>|<runner>|<pkg>   MCP local command (runner 必须是 bunx/npx)
#   B|<name>                  plugin 数组条目 (去重)
#   C|<name>                  provider.*.npm 字段值 (内置包, 调用方需跳过)
#   W|<msg>                   warn: 配置异常 (如 command 形如不匹配)
#   I|<msg>                   info: 跳过 (如 runner 非 bunx/npx)
# 失败: opencode.json 缺失/解析失败 → 返回非 0 + stderr 错误
_scan_opencode_packages() {
    local cfg="$OC_CONFIG_FILE"
    if [ ! -f "$cfg" ]; then
        echo "[err] opencode.json 不存在: $cfg" >&2
        return 1
    fi
    python3 - "$cfg" <<'PYEOF'
import json, sys
try:
    with open(sys.argv[1], encoding="utf-8") as f:
        cfg = json.load(f)
except json.JSONDecodeError as e:
    print(f"[err] opencode.json 解析失败: {e}", file=sys.stderr)
    sys.exit(1)

# Group A: MCP local command (runner 必须是 bunx/npx)
for name, mcp in cfg.get("mcp", {}).items():
    if mcp.get("type") != "local":
        continue
    cmd = mcp.get("command", []) or []
    if len(cmd) < 2:
        print(f"W|mcp.{name}.command 形如 [runner, pkg], 实际 {cmd}")
        continue
    runner, pkg = cmd[0], cmd[1]
    if runner not in ("bunx", "npx"):
        print(f"I|mcp.{name} runner={runner} 非 bunx/npx, 跳过")
        continue
    print(f"A|{name}|{runner}|{pkg}")

# Group B: plugin 列表 (去重)
seen = set()
for pkg in cfg.get("plugin", []):
    if pkg in seen:
        continue
    seen.add(pkg)
    print(f"B|{pkg}")

# Group C: provider.*.npm (内置包, 仅列出)
for _pname, prov in cfg.get("provider", {}).items():
    npm = prov.get("npm", "")
    if npm:
        print(f"C|{npm}")
PYEOF
}

# 刷新一个 bunx/npx 包 (MCP local)
# 参数: name (MCP 条目名), runner (bunx|npx), pkg_spec (形如 name@latest 或 name)
# DRY_RUN=1 时跳过真实 bun pm cache rm / bunx, 仅打印
_refresh_bunx_package() {
    local name="$1" runner="$2" pkg_spec="$3"
    if [ -z "$pkg_spec" ]; then
        warn "$name: 缺少包名, 跳过"
        return 0
    fi
    case "$pkg_spec" in
        *@*) ;;
        *)   pkg_spec="${pkg_spec}@latest" ;;
    esac

    if [ "$runner" = "npx" ] || ! command -v bun >/dev/null 2>&1; then
        warn "$name: 需 bun (当前 runner=$runner); 请用 oc plugins install-think 切换到 bunx 后再刷"
        return 0
    fi

    if [ "${DRY_RUN:-0}" = "1" ]; then
        info "[DRY_RUN] $name: 跳过 bun pm cache rm + bunx $pkg_spec"
        ok "$name: $pkg_spec (dry-run)"
        return 0
    fi

    info "清除 $name bun 缓存..."
    bun pm cache rm 2>/dev/null || true

    info "重新拉取 $name 最新版..."
    _run_with_timeout 15 bunx "$pkg_spec" --version 2>/dev/null &
    wait $! 2>/dev/null || true

    local bare_name="${pkg_spec%@*}"
    local cached
    cached=$(_find_bun_cache_package "$bare_name" || true)
    if [ -n "$cached" ]; then
        ok "$name: $(basename "$cached")"
    else
        warn "$name: 未找到缓存, 首次启动时会自动拉取"
    fi
}

# 刷新一个 npm plugin 包
# 参数: name (plugin 条目名)
# DRY_RUN=1 时跳过真实 npm update, 仅打印
_refresh_npm_package() {
    local name="$1"
    local oc_dir
    oc_dir=$(dirname "$OC_CONFIG_FILE")

    if [ ! -f "${oc_dir}/package.json" ]; then
        warn "$name: opencode 目录无 package.json, 首次启动时会自动拉取"
        return 0
    fi
    if ! command -v npm >/dev/null 2>&1; then
        warn "$name: npm 未安装, 跳过"
        return 0
    fi

    if [ "${DRY_RUN:-0}" = "1" ]; then
        info "[DRY_RUN] $name: 跳过 npm update $name"
        ok "$name: v? (dry-run)"
        return 0
    fi

    info "更新 $name (npm update)..."
    if (cd "$oc_dir" && npm update "$name" 2>/dev/null); then
        local ver
        ver=$(cd "$oc_dir" && node -e "try{console.log(require('${name}/package.json').version)}catch(e){console.log('?')}" 2>/dev/null || echo "?")
        ok "$name: v${ver}"
    else
        warn "$name: npm update 失败, opencode 启动时会自动拉取"
    fi
}

_refresh_global_npm_package() {
    local name="$1"
    local npm_runner=""
    if command -v bun >/dev/null 2>&1; then
        npm_runner="bun"
    elif command -v npm >/dev/null 2>&1; then
        npm_runner="npm"
    else
        warn "$name: bun/npm 均未安装, 跳过"
        return 0
    fi

    if [ "${DRY_RUN:-0}" = "1" ]; then
        info "[DRY_RUN] $name: 跳过 $npm_runner install -g $name@latest"
        ok "$name: v? (dry-run)"
        return 0
    fi

    info "更新全局工具 $name..."
    if $npm_runner install -g "$name"@latest 2>&1; then
        local ver
        ver=$($name --version 2>/dev/null || echo "?")
        ok "$name: v${ver}"
    else
        warn "$name: 全局更新失败"
    fi
}

# 刷新所有插件缓存 (从 opencode.json 全量扫描)
# 环境变量: DRY_RUN=1 跳过真实网络/磁盘 (用于测试/预览)
plugins_refresh_cache() {
    echo
    echo "${C_BOLD}刷新 NPM 工具${C_RESET}"
    echo

    if [ ! -f "$OC_CONFIG_FILE" ]; then
        warn "opencode 配置文件不存在: $OC_CONFIG_FILE"
        return 1
    fi
    if ! command -v python3 &>/dev/null; then
        warn "python3 未安装 (JSON 操作需要)"
        return 1
    fi

    local scan_output
    if ! scan_output=$(_scan_opencode_packages); then
        warn "扫描 opencode.json 失败 (见上方错误)"
        return 1
    fi

    # 分组
    local -a builtin_names=()
    local mcp_n=0 plugin_n=0 builtin_n=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        case "$line" in
            A\|*)
                mcp_n=$((mcp_n+1))
                local name runner pkg
                name=$(echo "$line" | cut -d'|' -f2)
                runner=$(echo "$line" | cut -d'|' -f3)
                pkg=$(echo "$line" | cut -d'|' -f4)
                _refresh_bunx_package "$name" "$runner" "$pkg" || true
                ;;
            B\|*)
                plugin_n=$((plugin_n+1))
                local name
                name=$(echo "$line" | cut -d'|' -f2)
                _refresh_npm_package "$name" || true
                ;;
            C\|*)
                builtin_n=$((builtin_n+1))
                builtin_names+=("$(echo "$line" | cut -d'|' -f2)")
                ;;
            W\|*)
                warn "$(echo "$line" | cut -d'|' -f2-)"
                ;;
            I\|*)
                info "$(echo "$line" | cut -d'|' -f2-)"
                ;;
        esac
    done <<< "$scan_output"

    if [ "${#builtin_names[@]}" -gt 0 ]; then
        info "跳过 ${#builtin_names[@]} 个内置包: $(IFS=,; echo "${builtin_names[*]}")"
    fi
    _refresh_global_npm_package "codegraph" || true
    info "扫描结果: $mcp_n 个 MCP 包, $plugin_n 个 plugin 包, $builtin_n 个内置 ai-sdk 包"
}

plugins_tui() {
    if [ ! -f "$OC_CONFIG_FILE" ]; then
        die "opencode 配置文件不存在: $OC_CONFIG_FILE"
    fi

    if ! command -v python3 &>/dev/null; then
        die "python3 未安装"
    fi

    while true; do
        clear
        local pad
        pad=$(_center_pad 50)
        echo
        _divider
        echo
        echo "${pad}${C_BOLD}${C_CYAN}🔌 插件管理${C_RESET}"
        echo
        _divider
        echo

        local status_output
        status_output=$(_get_plugin_status)

        local think_status think_runner think_pkg think_enabled
        think_status=$(echo "$status_output" | grep "^think|" | cut -d'|' -f2)
        think_runner=$(echo "$status_output" | grep "^think|" | cut -d'|' -f3)
        think_pkg=$(echo "$status_output" | grep "^think|" | cut -d'|' -f4)
        think_enabled=$(echo "$status_output" | grep "^think|" | cut -d'|' -f5)

        local dcp_status bun_status
        dcp_status=$(echo "$status_output" | grep "^dcp|" | cut -d'|' -f2)
        bun_status=$(echo "$status_output" | grep "^bun|" | cut -d'|' -f2)

        echo "${pad}${C_BOLD}当前状态：${C_RESET}"
        if [ "$think_status" = "found" ]; then
            if [ "$think_enabled" = "enabled" ]; then
                echo "${pad}  ${C_GREEN}✓${C_RESET} think MCP: ${C_CYAN}$think_runner${C_RESET} $think_pkg"
            else
                echo "${pad}  ${C_YELLOW}!${C_RESET} think MCP: 已禁用"
            fi
        else
            echo "  ${C_RED}✗${C_RESET} think MCP: 未配置"
        fi

        if [ "$dcp_status" = "found" ]; then
            echo "  ${C_GREEN}✓${C_RESET} DCP plugin: ${C_CYAN}$DCP_PKG${C_RESET}"
        else
            echo "  ${C_RED}✗${C_RESET} DCP plugin: 未配置"
        fi

        if [ "$bun_status" = "ok" ]; then
            local bun_ver
            bun_ver=$(bun --version 2>/dev/null || echo "?")
            echo "  ${C_GREEN}✓${C_RESET} bun: v${bun_ver}"
        else
            echo "  ${C_YELLOW}!${C_RESET} bun: 未安装"
        fi
        echo

        local options=()
        if [ "$think_status" = "missing" ]; then
            options+=("➕ 安装 think MCP")
        elif [ "$think_runner" = "npx" ] && [ "$bun_status" = "ok" ]; then
            options+=("🔄 切换 think MCP 到 bunx")
        fi

        if [ "$dcp_status" = "missing" ]; then
            options+=("➕ 安装 DCP plugin")
        fi

        if [ "$bun_status" = "ok" ] && [ "$think_status" = "found" ]; then
            # 动态扫描当前要刷的 NPM 包名 (MCP local + plugin), 列在菜单里
            local all_pkgs
            all_pkgs=$(python3 - "$OC_CONFIG_FILE" <<'PYEOF' 2>/dev/null || echo ""
import json, sys
try:
    with open(sys.argv[1], encoding="utf-8") as f:
        cfg = json.load(f)
    names = []
    for ename, mcp in cfg.get("mcp", {}).items():
        if mcp.get("type") != "local":
            continue
        cmd = mcp.get("command", []) or []
        if len(cmd) < 2 or cmd[0] not in ("bunx", "npx"):
            continue
        names.append(ename)
    for pkg in cfg.get("plugin", []):
        if pkg and pkg not in names:
            names.append(pkg)
    print(" / ".join(names))
except Exception:
    pass
PYEOF
)
            if [ -n "$all_pkgs" ]; then
                options+=("🔄 刷新 NPM 工具: ${all_pkgs} / codegraph")
            else
                options+=("🔄 刷新所有 NPM 工具")
            fi
        fi

        options+=("⬅  返回主菜单")

        local action
        action=$(printf '%s\n' "${options[@]}" | fzf --ansi --height=50% --prompt="选择操作 > " --no-info \
            --border rounded --border-label=" 插件管理 " --border-label-pos=center \
            --margin=1,20)

        case "${action:-}" in
            *"安装 think MCP"*)
                plugins_install_think
                ;;
            *"切换 think MCP 到 bunx"*)
                plugins_switch_think_bunx
                ;;
            *"安装 DCP plugin"*)
                plugins_install_dcp
                ;;
            *"刷新 NPM 工具"*|*"刷新所有 NPM 工具"*)
                plugins_refresh_cache
                ;;
            *)
                return
                ;;
        esac
    done
}

# ---------- 主流程 ----------
# 在线获取指定 tag 的 SHA256SUMS 中当前 asset 的 hash；失败返回非 0
fetch_remote_hash() {
    local tag="$1" asset
    asset=$(detect_asset)
    local sums_url="${RELEASES_URL}/download/${tag}/SHA256SUMS"
    local sums; sums=$(curl -fsSL "$sums_url" 2>/dev/null) || return 1
    [ -n "$sums" ] || return 1
    printf '%s\n' "$sums" | awk -v a="$asset" '$2==a || $2=="*"a {print $1; exit}'
}

# 主升级入口：tag 必填
# 策略：
#   1) 优先看本地包 + 在线 hash 是否命中 → 直接装本地（节省下载）
#   2) 在线能拿到 hash 但本地没命中 → 在线下载 + 校验 + 装
#   3) 在线拿不到（网络/限流）→ fallback：本地 VERSION 与 opencode --version 不一致就装本地
do_upgrade() {
    local tag="$1" asset
    asset=$(detect_asset)

    local local_dir=""; local_dir=$(find_local_dir 2>/dev/null || true)
    local local_ver=""
    [ -n "$local_dir" ] && local_ver=$(read_version_field "$local_dir/VERSION" BUNDLED_VERSION || true)

    local remote_hash=""
    remote_hash=$(fetch_remote_hash "$tag" 2>/dev/null || true)

    # ---------- 路径 A：在线可用 ----------
    if [ -n "$remote_hash" ]; then
        if [ -n "$local_dir" ]; then
            local local_hash; local_hash=$(file_sha256 "$local_dir/$asset")
            if [ "$remote_hash" = "$local_hash" ]; then
                info "本地包 hash 与 GitHub ($tag) 一致，跳过下载"
                install_from_local "$local_dir"
                return
            fi
            info "本地包与 $tag 不一致，转在线下载"
        fi
        # 在线下载流程
        local tmpdir; tmpdir=$(mktemp -d); trap "rm -rf '$tmpdir'" EXIT
        local file="$tmpdir/$asset"
        download_asset "$tag" "$asset" "$file"
        try_verify_sha256 "$tag" "$asset" "$file" "$tmpdir"
        extract_and_install "$file" "$tmpdir"
        ok "安装完成：$(${INSTALL_DIR}/${INSTALL_NAME} --version 2>/dev/null || echo "(版本未知)")"
        check_brew_shadow
        return
    fi

    # ---------- 路径 B：在线不可用，尝试本地 fallback ----------
    warn "无法在线获取 $tag 的 SHA256SUMS（网络/限流）"
    [ -z "$local_dir" ] && die "本地无可用包（候选：${LOCAL_DIR_CANDIDATES[*]}），无法离线安装"
    local cur; cur=$(current_version)
    if [ -n "$local_ver" ] && echo "$cur" | grep -qF "$local_ver"; then
        ok "已安装版本与本地包一致 ($local_ver)，无需操作"
        return
    fi
    info "离线 fallback：用本地包 $local_dir (BUNDLED=$local_ver) 替换当前 $cur"
    install_from_local "$local_dir"
}

main() {
    local cur latest local_dir local_ver
    cur=$(current_version)
    info "查询 GitHub releases..."
    latest=$(latest_tag 2>/dev/null || true)

    if [ -z "$latest" ]; then
        # 在线失败，尝试离线 fallback
        warn "无法获取最新 release（网络或 API 限流），进入离线模式"
        local_dir=$(find_local_dir 2>/dev/null || true)
        [ -z "$local_dir" ] && die "且本地无可用包，无法继续"
        local_ver=$(read_version_field "$local_dir/VERSION" BUNDLED_VERSION || true)
        info "本地包 BUNDLED_VERSION=$local_ver"
        if echo "$cur" | grep -qF "$local_ver"; then
            ok "已安装版本与本地包一致，无需操作"
            exit 0
        fi
        info "用本地包覆盖安装"
        install_from_local "$local_dir"
        exit 0
    fi

    while true; do
        banner "$cur" "$latest" "$OC_VERSION"

        local action; action=$(choose_action "$latest" || true)
        case "${action:-}" in
            *"升级到最新"*)
                do_upgrade "$latest"
                cur=$(current_version)
                ;;
            *"手工选择"*)
                local pick; pick=$(choose_release || true)
                [ -z "${pick:-}" ] && continue
                do_upgrade "$pick"
                cur=$(current_version)
                ;;
            *"仅查看"*)
                list_releases | awk -F'\t' '{
                    mark = ($4=="pre") ? "[预] " : "    ";
                    printf "%s%-30s  %s  %s\n", mark, $1, $3, $2
                }' | less -R
                ;;
            *"插件管理"*)
                plugins_tui
                ;;
            *"系统配置"*)
                setup_tui
                ;;
            *"自更新"*)
                self_update
                local ret=$?
                if [ $ret -eq 2 ]; then
                    echo
                    info "脚本已更新，请重新运行 oc"
                    exit 0
                fi
                ;;
            *)
                info "已退出"
                exit 0
                ;;
        esac
    done
}

case "${1:-}" in
    -h|--help)
        cat <<EOF
oc — opencode (LeXwDeX fork) 版本管理工具

用法：
  oc                  进入 TUI 选择升级
  oc latest           直接升级到最新版本
  oc <tag>            升级到指定 tag（如 oc v1.14.30-fork-2）
  oc list             列出所有 release
  oc current          显示当前已安装版本
  oc plugins          插件管理 (MCP / plugin / NPM 工具)
  oc plugins check    检查插件状态
  oc plugins install-think   安装 think MCP
  oc plugins install-dcp     安装 DCP plugin
  oc plugins switch-bunx     切换 think MCP 到 bunx
  oc plugins refresh         刷新 MCP/plugin NPM 工具 + 全局 codegraph
  oc setup            执行全部系统配置 (AGENTS + config + env)
  oc setup agents     安装/更新 AGENTS 仓库 (git clone/pull)
  oc setup config     应用 opencode.json 默认配置 (lsp/autoupdate/compaction)
  oc setup env        检查并注入 OPENCODE_EXPERIMENTAL_* 环境变量到 shell RC
  oc update           自更新本脚本
  oc -h | --help      显示本帮助

环境变量：
  OC_INSTALL_DIR       安装目录（默认 /usr/local/bin）
  OC_OPENCODE_NAME     目标命令名（默认 opencode）
  OC_LOCAL_DIR         本地包目录（含 VERSION + 平台压缩包）
                       命中且 hash 与 GitHub 一致时跳过下载；
                       离线时与 opencode --version 对比决定是否覆盖
  GITHUB_TOKEN         GitHub API token（可选，避免限流）

升级渠道：${RELEASES_URL}
EOF
        ;;
    latest)
        tag=$(latest_tag 2>/dev/null || true)
        if [ -z "$tag" ]; then
            warn "无法获取最新版本（网络/限流），尝试本地 fallback"
            ld=$(find_local_dir 2>/dev/null || true)
            [ -z "$ld" ] && die "且本地无可用包"
            tag=$(read_version_field "$ld/VERSION" BUNDLED_VERSION || true)
            [ -z "$tag" ] && die "本地 VERSION 缺 BUNDLED_VERSION"
            info "回退到本地 BUNDLED_VERSION=$tag"
        fi
        do_upgrade "$tag" ;;
    list)    list_releases ;;
    current) current_version ;;
    plugins)
        case "${2:-}" in
            check)          plugins_check ;;
            install-think)  plugins_install_think ;;
            install-dcp)    plugins_install_dcp ;;
            switch-bunx)    plugins_switch_think_bunx ;;
            refresh)        plugins_refresh_cache ;;
            "")             plugins_tui ;;
            *)              die "未知 plugins 子命令：$2（用 oc --help 查看）" ;;
        esac
        ;;
    update)  self_update ;;
    setup)
        case "${2:-}" in
            agents)   agents_install_or_update ;;
            config)   config_apply_defaults ;;
            env)      env_check_and_inject ;;
            "")
                agents_install_or_update || warn "AGENTS 步骤失败，继续..."
                config_apply_defaults     || warn "Config 步骤失败，继续..."
                env_check_and_inject      || warn "环境变量步骤失败，继续..."
                ;;
            *)  die "未知 setup 子命令：$2（用 oc --help 查看）" ;;
        esac
        ;;
    "")      main ;;
    v*|*-fork-*) do_upgrade "$1" ;;
    *) die "未知子命令：$1（用 oc --help 查看）" ;;
esac
