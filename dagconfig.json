{
  "$schema": "./dagconfig.schema.json",
  "$comment": "DAG Workflow 默认配置。创建工作流时如未显式指定，使用此处的默认值。可在 opencode.json 旁编辑此文件覆盖默认行为。",
  "defaults": {
    "node_timeout_ms": 1800000,
    "workflow_timeout_ms": 3600000,
    "max_concurrency": 3,
    "max_retries": 2,
    "retry_delay_ms": 5000,
    "default_worker_type": "implement",
    "failure_policy": "fail"
  },
  "models": {
    "fast": {
      "provider": "anthropic",
      "model": "claude-3-5-haiku-20241022"
    },
    "balanced": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514"
    },
    "powerful": {
      "provider": "anthropic",
      "model": "claude-opus-4-20250514"
    }
  },
  "limits": {
    "max_workflow_nodes": 100,
    "max_concurrency": 10,
    "sub_dag_max_depth": 3,
    "diagnosis_timeout_ms_min": 5000,
    "default_sub_dag_timeout_ms": 1800000
  }
}
